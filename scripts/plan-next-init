#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ "$#" -lt 1 ]; then
  echo "usage: plan-next-init <topic-slug-or-title>" >&2
  exit 1
fi

slugify() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g'
}

context="$($SCRIPT_DIR/plan-context)"
repo_slug="$(printf '%s\n' "$context" | awk -F= '/^REPO_SLUG=/{print $2}')"
branch="$(printf '%s\n' "$context" | awk -F= '/^BRANCH=/{print substr($0, index($0,$2))}')"
plan_path="$(printf '%s\n' "$context" | awk -F= '/^PLAN_PATH=/{print substr($0, index($0,$2))}')"

planforge_home="${PLANFORGE_HOME:-$HOME/.planforge}"
next_dir="$planforge_home/plans/$repo_slug/next"
slug="$(slugify "$*")"
file="$next_dir/$(date +%F)-$slug.md"

mkdir -p "$next_dir"

if [ ! -f "$file" ]; then
  now="$(date -Iseconds)"
  cat > "$file" <<EOF
# Deferred follow-up plan

Repo: $repo_slug
Source Branch: $branch
Created: $now
Status: deferred
Source Plan: $plan_path

## Deferred item
Describe the deferred work item clearly.

## Why deferred
Capture why this was deferred in the current session.

## Next-session plan
- [ ] Reproduce context
- [ ] Validate assumptions
- [ ] Implement focused fix
- [ ] Verify and review

## Risks
- 

## Acceptance criteria
- 
EOF
fi

printf '%s\n' "$file"
