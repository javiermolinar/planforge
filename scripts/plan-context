#!/usr/bin/env bash
set -euo pipefail

repo_path="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "plan-context: not inside a git repository" >&2
  exit 1
}

branch="$(git branch --show-current 2>/dev/null || true)"
if [ -z "$branch" ]; then
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
fi
if [ -z "$branch" ] || [ "$branch" = "HEAD" ]; then
  echo "plan-context: unable to determine current branch" >&2
  exit 1
fi

slugify() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g'
}

repo_slug="$(slugify "$(basename "$repo_path")")"
branch_slug="$(slugify "$branch")"
plan_path="$HOME/.planforge/plans/$repo_slug/$branch_slug.md"

printf 'REPO_SLUG=%s\n' "$repo_slug"
printf 'REPO_PATH=%s\n' "$repo_path"
printf 'BRANCH=%s\n' "$branch"
printf 'BRANCH_SLUG=%s\n' "$branch_slug"
printf 'PLAN_PATH=%s\n' "$plan_path"
