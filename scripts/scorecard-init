#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TEMPLATE="$SCRIPT_DIR/../docs/scorecard-template.md"

if [ "$#" -lt 1 ]; then
  echo "usage: scorecard-init <task-slug>" >&2
  exit 1
fi

slugify() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g'
}

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
slug="$(slugify "$*")"
out_dir="$repo_root/benchmarks/results"
out_path="$out_dir/$(date +%F)-$slug.md"

mkdir -p "$out_dir"
if [ ! -f "$out_path" ]; then
  cp "$TEMPLATE" "$out_path"
fi

printf '%s\n' "$out_path"
